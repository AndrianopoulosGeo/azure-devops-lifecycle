# =============================================================================
# Claude Skills — Project Configuration
# =============================================================================
# Copy this file to .env.claude at the root of your project repository.
# All commands read from this file to self-configure.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure DevOps
# -----------------------------------------------------------------------------
AZURE_DEVOPS_ORG=your-org
AZURE_DEVOPS_PROJECT=your-project
AZURE_DEVOPS_REPO=your-repo-name
AZURE_DEVOPS_PAT=your-pat-token

# -----------------------------------------------------------------------------
# Deploy Target: hetzner | azure | vercel
# -----------------------------------------------------------------------------
DEPLOY_TARGET=hetzner

# -----------------------------------------------------------------------------
# Environment URLs
# -----------------------------------------------------------------------------
STAGING_URL=https://staging.example.com
PRODUCTION_URL=https://example.com

# -----------------------------------------------------------------------------
# Tech Stack: nextjs | dotnet | python
# -----------------------------------------------------------------------------
TECH_STACK=nextjs

# -----------------------------------------------------------------------------
# Branch Strategy (default: gitflow)
# -----------------------------------------------------------------------------
BRANCH_STRATEGY=gitflow

# -----------------------------------------------------------------------------
# Pipeline IDs (auto-populated by /init-project after pipeline creation)
# -----------------------------------------------------------------------------
STAGING_PIPELINE_ID=
PRODUCTION_PIPELINE_ID=

# -----------------------------------------------------------------------------
# Optional: SSH deployment (for hetzner deploy target)
# -----------------------------------------------------------------------------
# SSH_HOST=your-server.example.com
# SSH_USER=deploy
# SSH_KEY_PATH=~/.ssh/id_rsa
# REMOTE_APP_PATH=/var/www/app

# -----------------------------------------------------------------------------
# Optional: Azure deployment (for azure deploy target)
# -----------------------------------------------------------------------------
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=
# AZURE_APP_SERVICE_NAME=
# AZURE_CONTAINER_REGISTRY=

# -----------------------------------------------------------------------------
# Optional: Vercel deployment (for vercel deploy target)
# -----------------------------------------------------------------------------
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
